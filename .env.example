# Backend Environment Variables
PORT=5001
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/jobtracker
JWT_SECRET=your_super_secret_jwt_key

# Groq API Keys (get from https://console.groq.com)
GROQ_API_KEY_1=gsk_your_first_key
GROQ_API_KEY_2=gsk_your_second_key
GROQ_API_KEY_3=gsk_your_third_key

# Gemini API Keys (get from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY_1=AIza_your_first_key
GEMINI_API_KEY_2=AIza_your_second_key

# OpenRouter API Keys (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY_1=sk-or_your_first_key
OPENROUTER_API_KEY_2=sk-or_your_second_key

# Frontend Environment Variable
VITE_API_URL=http://localhost:5001/api